<Window x:Class="MovieLibrary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movie Library" Height="600" Width="900">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ADD MOVIE -->
        <GroupBox Header="Add Movie" Grid.Row="0" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal">

                <StackPanel Margin="2">
                    <TextBlock Text="Title"/>
                    <TextBox x:Name="TxtTitle" Width="120"/>
                </StackPanel>

                <StackPanel Margin="2">
                    <TextBlock Text="Director"/>
                    <TextBox x:Name="TxtDirector" Width="120"/>
                </StackPanel>

                <StackPanel Margin="2">
                    <TextBlock Text="Genre"/>
                    <TextBox x:Name="TxtGenre" Width="80"/>
                </StackPanel>

                <StackPanel Margin="2">
                    <TextBlock Text="Year"/>
                    <TextBox x:Name="TxtYear" Width="60"/>
                </StackPanel>

                <Button Content="Add"
                        Width="60"
                        Margin="5"
                        VerticalAlignment="Bottom"
                        Click="BtnAdd_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- SEARCH -->
        <GroupBox Header="Search" Grid.Row="1" Margin="0,0,0,5">
            <WrapPanel>
                <TextBox x:Name="TxtSearch" Width="200" Margin="2"/>
                <Button Content="By Title" Margin="2" Click="BtnSearchTitle_Click"/>
                <Button Content="By ID" Margin="2" Click="BtnSearchId_Click"/>
                <Button Content="Show All" Margin="2" Click="BtnShowAll_Click"/>
            </WrapPanel>
        </GroupBox>

        <!-- ACTIONS -->
        <GroupBox Header="Actions" Grid.Row="2" Margin="0,0,0,5">
            <StackPanel>

                <!-- SORT -->
                <WrapPanel>
                    <Button Content="Sort Title" Margin="2" Click="BtnSortTitle_Click"/>
                    <Button Content="Sort Year" Margin="2" Click="BtnSortYear_Click"/>
                </WrapPanel>

                <!-- BORROW / RETURN -->
                <StackPanel Orientation="Horizontal" Margin="10,5,0,5">

                    <StackPanel Margin="2">
                        <TextBlock Text="Movie ID"/>
                        <TextBox x:Name="TxtBorrowMovieId" Width="100"/>
                    </StackPanel>

                    <StackPanel Margin="2">
                        <TextBlock Text="Person Name"/>
                        <TextBox x:Name="TxtBorrowName" Width="120"/>
                    </StackPanel>

                    <Button Content="Borrow"
                            Margin="10,18,2,2"
                            Click="BtnBorrow_Click"/>

                    <Button Content="Return"
                            Margin="10,18,2,2"
                            Click="BtnReturn_Click"/>
                </StackPanel>

                <!-- FILE -->
                <WrapPanel>
                    <Button Content="Export JSON" Margin="2" Click="BtnExport_Click"/>
                    <Button Content="Import JSON" Margin="2" Click="BtnImport_Click"/>
                    <Button Content="Export Notifications" Margin="2" Click="BtnExportNotifications_Click"/>
                </WrapPanel>

            </StackPanel>
        </GroupBox>

        <!-- GRID -->
        <DataGrid x:Name="MovieGrid"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="MovieGrid_SelectionChanged">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding MovieId}" Width="80"/>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="160"/>
                <DataGridTextColumn Header="Director" Binding="{Binding Director}" Width="120"/>
                <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="100"/>
                <DataGridTextColumn Header="Year" Binding="{Binding ReleaseYear}" Width="70"/>
                <DataGridTextColumn Header="Available" Binding="{Binding IsAvailable}" Width="90"/>
                <DataGridTextColumn Header="Borrowed By" Binding="{Binding BorrowedBy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- STATUS -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>